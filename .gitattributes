# 기본: 자동 판별 후 OS에 맞게 변환
* text=auto

# Linux에서 실행되는 파일들은 무조건 LF (CRLF 섞이면 실행 불가)
*.sh            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.conf          text eol=lf
Dockerfile      text eol=lf
.env*           text eol=lf

# 바이너리는 변환 금지
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.webp          binary
*.ico           binary
*.woff          binary
*.woff2         binary
*.ttf           binary
*.otf           binary
*.mp3           binary
*.mp4           binary
*.pdf           binary
